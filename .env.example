# --- Steam -------------------------------------------------------------------
# API key: https://steamcommunity.com/dev/apikey
# SteamID (64-bit): https://steamid.io  (the big number, e.g. 7656119...)
STEAM_API_KEY=
STEAM_ID=

# --- RetroAchievements -------------------------------------------------------
# Settings -> Keys on retroachievements.org
RA_USERNAME=
RA_API_KEY=
# Whose record to pull (defaults to RA_USERNAME if left blank)
RA_TARGET_USER=

# --- Sync behaviour ----------------------------------------------------------
SYNC_INTERVAL_HOURS=12
REQUEST_DELAY_SECONDS=0.4

# --- IGDB cross-platform game matching (optional, phase 2) -------------------
# Create a Twitch app: https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
