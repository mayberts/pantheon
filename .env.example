# --- Steam -------------------------------------------------------------------
# API key: https://steamcommunity.com/dev/apikey
# SteamID (64-bit): https://steamid.io  (the big number, e.g. 7656119...)
STEAM_API_KEY=
STEAM_ID=

# --- RetroAchievements -------------------------------------------------------
# Settings -> Keys on retroachievements.org
RA_USERNAME=
RA_API_KEY=
# Whose record to pull (defaults to RA_USERNAME if left blank)
RA_TARGET_USER=

# --- Xbox --------------------------------------------------------------------
# Register an app at https://portal.azure.com
# XBOX_REFRESH_TOKEN is written automatically after completing /api/xbox-setup
XBOX_CLIENT_ID=
XBOX_REFRESH_TOKEN=

# --- Sync behaviour ----------------------------------------------------------
SYNC_INTERVAL_HOURS=12
REQUEST_DELAY_SECONDS=0.4

# --- IGDB cover art (optional) -----------------------------------------------
# Create a Twitch app: https://dev.twitch.tv/console/apps
# Fetches portrait cover art for non-Steam games as a fallback
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- SteamGridDB cover art (optional) ----------------------------------------
# Get your API key: https://www.steamgriddb.com/profile/preferences/api
# Fetches landscape grid art (460x215 / 920x430) for all platforms.
# Preferred over IGDB covers when available.
SGDB_API_KEY=

# --- Wargaming ---------------------------------------------------------------
# Register an app at https://developers.wargaming.net/
# WARGAMING_REGION: na | eu | asia
WARGAMING_APP_ID=
WARGAMING_NICKNAME=
WARGAMING_REGION=eu

# --- Guild Wars 2 ------------------------------------------------------------
# Generate an API key at https://account.arena.net/applications
# Requires the "progression" permission scope
GW2_API_KEY=

# --- Exophase (optional, Xbox 360 locked achievements) -----------------------
# Credentials extracted from browser session on exophase.com
# Used to import locked achievement data for Xbox 360 games
EXOPHASE_PLAYER_ID=
EXOPHASE_REMEMBERME=
EXOPHASE_XF_USER=
EXOPHASE_ACCESS_TOKEN=
